{
  "manifest_version": 3,
  "name": "LeLinc Cookie Grant",
  "version": "1.0.0",
  "description": "Captures your login session after you log in normally on a connected platform, so LeLinc's browser can use it. Your password never leaves your browser.",
  "key": "",
  "permissions": ["cookies", "tabs", "storage", "alarms"],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.linkedin.com/*",
    "*://*.facebook.com/*",
    "*://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://lelinc.keyview.com.au/*",
      "http://localhost/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeLinc Cookie Grant"
  }
}
